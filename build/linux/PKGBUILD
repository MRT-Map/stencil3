# Maintainer: 7d <61975820+iiiii7d@users.noreply.github.com>
pkgname=stencil3
pkgver=3.0.0_alpha.4
pkgrel=1
makedepends=('dpkg')
arch=('x86_64' 'aarch64')
pkgdesc="Map editor for MRT Map data"
license=('GPL-3.0-only')
url="https://github.com/mrt-map/stencil3"
source_x86_64=("$pkgname-$pkgver.deb::$url/releases/download/v${pkgver//_/-}/stencil3_${pkgver//_/-}_amd64.deb")
source_aarch64=("$pkgname-$pkgver.deb::$url/releases/download/v${pkgver//_/-}/stencil3_${pkgver//_/-}_arm64.deb")
sha256sums_x86_64=('188ac7aec007fcf058e39810743a11cc81fc31de03526fca74ea062fe6e0030c')
sha256sums_aarch64=('00a579d9e8135ee8074980b4361ced4ffffeb6af391ec36fa01b41eb9fac4671')

if [[ -f PKGBUILD ]]; then
    cp PKGBUILD stencil3.install
fi
install=stencil3.install

package() {
    dpkg -x "$pkgname-$pkgver.deb" "$pkgdir/"
}

post_install() {
    update-desktop-database /usr/share/applications || true
}

post_remove() {
    rm -r "~/.local/share/stencil3" || true
    rm -r "~/.cache/stencil3" || true
}

